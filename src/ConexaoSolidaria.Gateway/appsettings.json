{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "identity",
        "RateLimiterPolicy": "auth",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "campanhas": {
        "ClusterId": "campaigns",
        "Match": {
          "Path": "/api/campanhas/{**catch-all}"
        }
      },
      "doacoes": {
        "ClusterId": "campaigns",
        "RateLimiterPolicy": "donation",
        "Match": {
          "Path": "/api/doacoes/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity-api": {
            "Address": "http://identity-api"
          }
        }
      },
      "campaigns": {
        "Destinations": {
          "campaigns-api": {
            "Address": "http://campaigns-api"
          }
        }
      }
    }
  }
}
