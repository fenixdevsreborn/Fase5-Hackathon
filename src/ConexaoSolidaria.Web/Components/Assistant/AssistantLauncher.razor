@* Botao flutuante do Assistente Solidario (IA). So renderiza quando OPENAI_API_KEY esta
   configurada (degradacao graciosa: sem chave, a plataforma funciona sem a feature). *@
@using ConexaoSolidaria.Web.Services.Ai
@inject AiChatClientProvider Ai

@if (Ai.Enabled)
{
    @if (_aberto)
    {
        <MudPaper Elevation="12"
                  Class="d-flex flex-column"
                  Style="position:fixed; bottom:92px; right:24px; width:min(380px, calc(100vw - 32px)); height:min(540px, calc(100vh - 140px)); z-index:1400; border-radius:16px; overflow:hidden">
            <div class="d-flex align-center px-3 py-2"
                 style="background:var(--mud-palette-primary); color:var(--mud-palette-primary-text); gap:8px">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2" Style="color:inherit; flex:1">Assistente Solidario</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               Style="color:inherit"
                               OnClick="Alternar"
                               aria-label="Fechar assistente" />
            </div>
            <AssistantChat />
        </MudPaper>
    }

    <div style="position:fixed; bottom:24px; right:24px; z-index:1400">
        <MudFab Color="Color.Primary"
                StartIcon="@(_aberto ? Icons.Material.Filled.Close : Icons.Material.Filled.SmartToy)"
                OnClick="Alternar"
                aria-label="@(_aberto ? "Fechar Assistente Solidario" : "Abrir Assistente Solidario")" />
    </div>
}

@code {
    private bool _aberto;

    private void Alternar() => _aberto = !_aberto;
}
