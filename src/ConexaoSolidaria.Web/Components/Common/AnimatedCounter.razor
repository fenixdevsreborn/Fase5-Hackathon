@using System.Globalization
@inject IJSRuntime JS
@implements IAsyncDisposable

<span class="cs-animated-counter">@Prefix@_display@Suffix</span>

@code {
    /// <summary>Valor final que sera atingido pela animacao.</summary>
    [Parameter] public decimal Value { get; set; }

    /// <summary>Formato numerico .NET (ex.: "N0", "N2"). Nulo/vazio usa cultura pt-BR padrao.</summary>
    [Parameter] public string? Format { get; set; }

    /// <summary>Texto exibido antes do numero (ex.: "R$ ").</summary>
    [Parameter] public string? Prefix { get; set; }

    /// <summary>Texto exibido depois do numero (ex.: " campanhas").</summary>
    [Parameter] public string? Suffix { get; set; }

    /// <summary>Duracao aproximada da animacao em milissegundos (padrao 1000).</summary>
    [Parameter] public int DurationMs { get; set; } = 1000;

    private static readonly CultureInfo Ptbr = CultureInfo.GetCultureInfo("pt-BR");

    private string _display = string.Empty;
    private bool _started;
    private IJSObjectReference? _module;
    private CancellationTokenSource? _cts;

    protected override void OnInitialized() => _display = Render(0m);

    protected override void OnParametersSet()
    {
        // Se o valor mudar depois da animacao inicial, mostra o valor atualizado direto.
        if (_started)
        {
            _display = Render(Value);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started)
        {
            return;
        }

        _started = true;

        bool reduced;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/reduced-motion.js");
            reduced = await _module.InvokeAsync<bool>("prefersReducedMotion");
        }
        catch
        {
            // JS indisponivel: mostra o valor final imediatamente (sem quebrar a UI).
            SetFinal();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (reduced || Value == 0m)
        {
            SetFinal();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _cts = new CancellationTokenSource();
        var token = _cts.Token;
        const int steps = 30;
        var interval = Math.Max(16, DurationMs / steps);

        try
        {
            for (var i = 1; i <= steps; i++)
            {
                await Task.Delay(interval, token);
                // Ease-out (desacelera no fim) para uma sensacao mais natural.
                var progress = 1d - Math.Pow(1d - (double)i / steps, 3);
                _display = Render(Value * (decimal)progress);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }

        SetFinal();
        await InvokeAsync(StateHasChanged);
    }

    private void SetFinal() => _display = Render(Value);

    private string Render(decimal value) =>
        string.IsNullOrEmpty(Format) ? value.ToString(Ptbr) : value.ToString(Format, Ptbr);

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();

        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuito ja encerrado; nada a fazer.
            }
        }
    }
}
