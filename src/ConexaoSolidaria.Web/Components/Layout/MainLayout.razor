@inherits LayoutComponentBase
@using ConexaoSolidaria.Contracts.Events
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject NotificationDispatcher Notifications
@inject ISnackbar Snackbar

<MudThemeProvider Theme="AppTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       aria-label="Abrir menu de navegacao"
                       OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.VolunteerActivism" Class="ml-1 mr-2" />
        <MudText Typo="Typo.h6" Class="mud-text-truncate">Conexao Solidaria</MudText>
        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex">
                    Ola, @(context.User.Identity?.Name ?? "usuario")
                </MudText>
                <MudButton Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Logout"
                           OnClick="LogoutAsync">
                    Sair
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/entrar" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login">
                    Entrar
                </MudButton>
                <MudButton Href="/cadastrar"
                           Variant="Variant.Outlined"
                           Color="Color.Inherit"
                           Class="ml-2 d-none d-sm-flex">
                    Cadastrar
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="2"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Color="Color.Primary">Navegacao</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-6 pb-4 px-4">
            @Body
        </MudContainer>

        <footer class="cs-footer mt-8">
            <MudContainer MaxWidth="MaxWidth.Large" Class="py-6 px-4">
                <MudText Typo="Typo.subtitle1" Style="color:#fff;">Conexao Solidaria</MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,.75);" Class="mt-1">
                    Plataforma de campanhas e doacoes transparentes.
                </MudText>
                <div class="mt-3">
                    <a href="/campanhas" class="mr-4">Campanhas</a>
                    <a href="/transparencia" class="mr-4">Transparencia</a>
                    <a href="/status">Status</a>
                </div>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.6);" Class="d-block mt-4">
                    &copy; @DateTime.UtcNow.Year Conexao Solidaria - FIAP Hackathon.
                </MudText>
            </MudContainer>
        </footer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro inesperado.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        // Toast global e festivo quando qualquer campanha atinge a meta — para todos os
        // usuarios conectados. A notificacao chega de outra thread (consumidor RabbitMQ).
        Notifications.Received += OnNotificacaoRecebida;
    }

    private void OnNotificacaoRecebida(DoacaoProcessadaNotification n)
    {
        if (!n.MetaAtingida)
        {
            return;
        }

        _ = InvokeAsync(() =>
            Snackbar.Add(
                $"\U0001F389 A campanha '{n.CampanhaTitulo}' atingiu a meta!",
                Severity.Success,
                config =>
                {
                    config.VisibleStateDuration = 8000;
                    config.SnackbarVariant = Variant.Filled;
                }));
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        Notifications.Received -= OnNotificacaoRecebida;
    }
}
