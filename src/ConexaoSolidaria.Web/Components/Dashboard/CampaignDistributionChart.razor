@* Donut: distribuição do valor arrecadado entre as campanhas (apenas as com valor > 0). *@
@using System.Globalization

@if (_values.Length == 0)
{
    <div class="d-flex align-center justify-center" style="height:300px">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Ainda não há arrecadação registrada para exibir a distribuição.
        </MudText>
    </div>
}
else
{
    <MudChart T="double"
              ChartType="ChartType.Donut"
              Width="100%"
              Height="300px"
              ChartSeries="_series"
              ChartLabels="_labels"
              ChartOptions="_options" />

    <MudSimpleTable Dense="true" Bordered="false" Striped="false" Elevation="0" Class="mt-2">
        <tbody>
            @for (var i = 0; i < _values.Length; i++)
            {
                <tr>
                    <td>@_labels[i]</td>
                    <td style="text-align:right">@_values[i].ToString("C", Br)</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private static readonly CultureInfo Br = CultureInfo.GetCultureInfo("pt-BR");

    [Parameter] public IReadOnlyList<CampanhaDto> Campanhas { get; set; } = Array.Empty<CampanhaDto>();

    /// <summary>Quantidade máxima de fatias exibidas (as demais são agrupadas em "Outras").</summary>
    [Parameter] public int MaxFatias { get; set; } = 7;

    private double[] _values = Array.Empty<double>();
    private string[] _labels = Array.Empty<string>();
    private List<ChartSeries<double>> _series = new();

    // Referencia dos dados ja processados: evita reprocessar o LINQ pesado e
    // re-renderizar o grafico quando o pai renderiza sem que os dados mudem.
    private IReadOnlyList<CampanhaDto>? _processadas;

    private readonly ChartOptions _options = new()
    {
        ChartPalette = new[]
        {
            "#0b3b60", "#23a36d", "#0f7594", "#f4b942",
            "#c43838", "#7e57c2", "#26a69a", "#8d6e63",
        },
    };

    protected override void OnParametersSet()
    {
        // Dados imutaveis apos o carregamento: so recalcula quando a referencia muda.
        if (ReferenceEquals(_processadas, Campanhas))
        {
            return;
        }
        _processadas = Campanhas;

        var ordenadas = Campanhas
            .Where(c => c.ValorTotalArrecadado > 0)
            .OrderByDescending(c => c.ValorTotalArrecadado)
            .ToList();

        var labels = new List<string>();
        var values = new List<double>();

        var principais = ordenadas.Take(MaxFatias).ToList();
        foreach (var c in principais)
        {
            labels.Add(Encurtar(c.Titulo));
            values.Add((double)c.ValorTotalArrecadado);
        }

        var resto = ordenadas.Skip(MaxFatias).ToList();
        if (resto.Count > 0)
        {
            labels.Add($"Outras ({resto.Count})");
            values.Add((double)resto.Sum(c => c.ValorTotalArrecadado));
        }

        _labels = labels.ToArray();
        _values = values.ToArray();
        _series = _values.Length == 0
            ? new List<ChartSeries<double>>()
            : new List<ChartSeries<double>> { new() { Data = _values } };
    }

    private static string Encurtar(string titulo) =>
        string.IsNullOrEmpty(titulo) || titulo.Length <= 22 ? titulo : titulo[..21] + "…";
}
