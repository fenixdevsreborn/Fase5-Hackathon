@* KPI de negócio reutilizável do painel do gestor. *@

<MudPaper Elevation="1" Class="pa-4" Style="height:100%">
    <div class="d-flex align-center" style="gap:16px">
        <MudAvatar Color="Cor" Variant="Variant.Filled" Rounded="true" Size="Size.Large">
            <MudIcon Icon="@Icone" />
        </MudAvatar>
        <div style="min-width:0">
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Titulo</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:600">@Valor</MudText>
        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string Valor { get; set; } = string.Empty;
    [Parameter] public string Icone { get; set; } = Icons.Material.Filled.Insights;
    [Parameter] public Color Cor { get; set; } = Color.Primary;
}
