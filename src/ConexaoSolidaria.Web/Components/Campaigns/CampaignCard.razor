@using System.Globalization

<div class="cs-card-wrap">
    <MudCard Elevation="2" Class="cs-campaign-card">
        <MudCardContent Class="cs-campaign-card__content">
            <div class="d-flex justify-space-between align-start mb-2" style="gap:8px;">
                <MudText Typo="Typo.h6"
                         Style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.25;">
                    @Campanha.Titulo
                </MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="StatusColor" Class="ma-0">
                    @Campanha.Status
                </MudChip>
            </div>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4"
                     Style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;min-height:3.6em;">
                @Campanha.Descricao
            </MudText>

            <div class="cs-campaign-card__spacer"></div>

            <CampaignProgress Meta="Campanha.MetaFinanceira" Arrecadado="Campanha.ValorTotalArrecadado" Dense="true" />

            <div class="d-flex align-center mt-3" style="gap:6px;">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Secondary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">@DiasRestantesLabel</MudText>
            </div>
        </MudCardContent>

        <MudCardActions Class="px-4 pb-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       EndIcon="@AcaoIcon"
                       Href="@($"/campanhas/{Campanha.Id}")">
                @AcaoLabel
            </MudButton>
        </MudCardActions>
    </MudCard>
</div>

@code {
    /// <summary>Campanha exibida no cartao.</summary>
    [Parameter, EditorRequired] public CampanhaDto Campanha { get; set; } = default!;

    private Color StatusColor => Campanha.Status switch
    {
        "Ativa" => Color.Success,
        "Concluida" => Color.Primary,
        "Cancelada" => Color.Error,
        _ => Color.Default,
    };

    private bool Ativa => Campanha.Status == "Ativa";
    private string AcaoLabel => Ativa ? "Doar" : "Ver campanha";
    private string AcaoIcon => Ativa ? Icons.Material.Filled.Favorite : Icons.Material.Filled.Visibility;

    private int DiasRestantes => Math.Max(0, (int)Math.Ceiling((Campanha.DataFim - DateTimeOffset.Now).TotalDays));

    private string DiasRestantesLabel => !Ativa
        ? "Campanha encerrada"
        : DiasRestantes switch
        {
            0 => "Ultimo dia",
            1 => "1 dia restante",
            _ => $"{DiasRestantes} dias restantes",
        };
}
