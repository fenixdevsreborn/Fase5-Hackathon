@* Escolha do modo de criacao de campanha: manual, IA ou planilha.
   Cada opcao leva para /gestor/campanhas/nova com ?modo=, que foca o metodo escolhido. *@

<MudDialog>
    <TitleContent>
        <div class="criar-camp-dlg__title">
            <span class="criar-camp-dlg__title-ico"><MudIcon Icon="@Icons.Material.Rounded.AddCircle" /></span>
            <div>
                <h2>Criar nova campanha</h2>
                <p>Escolha como você quer começar.</p>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="criar-camp-dlg__options">
            <button type="button" class="criar-camp-dlg__opt" @onclick="@(() => Ir("manual"))">
                <span class="criar-camp-dlg__opt-ico criar-camp-dlg__opt-ico--blue">
                    <MudIcon Icon="@Icons.Material.Rounded.DriveFileRenameOutline" />
                </span>
                <span class="criar-camp-dlg__opt-txt">
                    <strong>Criar</strong>
                    <small>Preencha os dados da campanha manualmente.</small>
                </span>
                <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Class="criar-camp-dlg__opt-go" />
            </button>

            <button type="button" class="criar-camp-dlg__opt" @onclick="@(() => Ir("ia"))">
                <span class="criar-camp-dlg__opt-ico criar-camp-dlg__opt-ico--violet">
                    <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" />
                </span>
                <span class="criar-camp-dlg__opt-txt">
                    <strong>Criar com IA</strong>
                    <small>Descreva a ideia e receba rascunhos prontos.</small>
                </span>
                <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Class="criar-camp-dlg__opt-go" />
            </button>

            <button type="button" class="criar-camp-dlg__opt" @onclick="@(() => Ir("planilha"))">
                <span class="criar-camp-dlg__opt-ico criar-camp-dlg__opt-ico--teal">
                    <MudIcon Icon="@Icons.Material.Rounded.TableChart" />
                </span>
                <span class="criar-camp-dlg__opt-txt">
                    <strong>Importar planilha</strong>
                    <small>Traga várias campanhas de um Excel ou CSV.</small>
                </span>
                <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Class="criar-camp-dlg__opt-go" />
            </button>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void Ir(string modo)
    {
        MudDialog.Close(DialogResult.Ok(modo));
        Nav.NavigateTo($"/gestor/campanhas/nova?modo={modo}");
    }

    private void Cancelar() => MudDialog.Cancel();
}
