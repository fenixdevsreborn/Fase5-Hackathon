  "cards": [
    {
      "dot": "cyan",
      "title": "As 4 tools expostas",
      "items": [
        "BuscarCampanhas -> GET /api/campanhas/search",
        "ObterCampanha -> GET /api/campanhas/{id}",
        "ObterEstatisticas -> /stats com fallback /transparencia",
        "MinhasDoacoes -> GET /api/doacoes/minhas (exige login)"
