{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Pipeline de Telemetria",
    "subtitle": "OpenTelemetry, Prometheus, Tempo, Grafana e Zabbix - da instrumentacao ao alerta",
    "viewBox": [1080, 760]
  },
  "stages": [
    { "label": "Servicos" },
    { "label": "Coleta" },
    { "label": "Armazenamento" },
    { "label": "Visualizacao" },
    { "label": "Alerta" }
  ],
  "nodes": [
    { "id": "gw", "type": "security", "label": "Gateway", "sublabel": "YARP", "stage": 0, "row": 0 },
    { "id": "identity", "type": "backend", "label": "Identity.Api", "sublabel": "auth", "stage": 0, "row": 1 },
    { "id": "campaigns", "type": "backend", "label": "Campaigns.Api", "sublabel": "dominio", "stage": 0, "row": 2 },
    { "id": "worker", "type": "backend", "label": "Worker", "sublabel": "consumo", "stage": 0, "row": 3 },
    { "id": "rabbit", "type": "messagebus", "label": "RabbitMQ", "sublabel": ":15692", "stage": 0, "row": 4 },

    { "id": "otel", "type": "cloud", "label": "OTel Collector", "sublabel": "OTLP", "stage": 1, "row": 1, "tag": "traces" },
    { "id": "prom", "type": "cloud", "label": "Prometheus", "sublabel": "scrape 5s", "stage": 1, "row": 3, "tag": "metricas" },
    { "id": "zabbix", "type": "cloud", "label": "Zabbix", "sublabel": "itens HTTP", "stage": 1, "row": 4 },

    { "id": "tempo", "type": "database", "label": "Tempo", "sublabel": "traces :3200", "stage": 2, "row": 1 },
    { "id": "tsdb", "type": "database", "label": "TSDB", "sublabel": "series temporais", "stage": 2, "row": 3 },

    { "id": "grafana", "type": "frontend", "label": "Grafana", "sublabel": "4 dashboards", "stage": 3, "row": 2, "tag": "negocio / app / fila / saude" },

    { "id": "alertas", "type": "security", "label": "Alertas", "sublabel": "regras provisionadas", "stage": 4, "row": 1 },
    { "id": "triggers", "type": "security", "label": "Triggers", "sublabel": "9 no template", "stage": 4, "row": 4 }
  ],
  "flows": [
    { "from": "gw", "to": "otel", "label": "spans HTTP", "classification": "traceparent" },
    { "from": "identity", "to": "otel", "label": "spans de auth" },
    { "from": "campaigns", "to": "otel", "label": "spans dominio", "variant": "emphasis" },

    { "from": "worker", "to": "prom", "label": "donations_*", "variant": "emphasis", "classification": "custom" },
    { "from": "rabbit", "to": "prom", "label": "ready / unacked" },
    { "from": "rabbit", "to": "zabbix", "label": "saude do broker", "variant": "dashed" },

    { "from": "otel", "to": "tempo", "label": "traces", "variant": "emphasis" },
    { "from": "prom", "to": "tsdb", "label": "amostras", "variant": "emphasis" },

    { "from": "tempo", "to": "grafana", "label": "trace explore", "classification": "read-only" },
    { "from": "tsdb", "to": "grafana", "label": "PromQL", "variant": "emphasis", "classification": "read-only" },

    { "from": "grafana", "to": "alertas", "label": "DLQ / Outbox / 5xx", "variant": "security" },
    { "from": "zabbix", "to": "triggers", "label": "checks HTTP", "variant": "dashed" }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "Instrumentacao unica",
      "items": [
        "ServiceDefaults liga OTel, /health, /alive e resiliencia HTTP",
        "Todo servico referencia o mesmo projeto - nada e opcional",
        "X-Correlation-Id do Gateway + traceparent ate o Worker",
        "/metrics exposto por prometheus-net, inclusive no Gateway"
      ]
    },
    {
      "dot": "emerald",
      "title": "Metricas de negocio",
      "items": [
        "conexao_donations_processed_total / rejected_total",
        "conexao_outbox_pending_messages e dead_letter_messages",
        "conexao_donation_processing_duration_seconds",
        "Valor e contagem por campanha (label campanha)"
      ]
    },
    {
      "dot": "rose",
      "title": "Do sintoma a causa",
      "items": [
        "Dashboard mostra o pico -> Explore abre o trace no Tempo",
        "Trace atravessa Gateway, Api, fila e Worker",
        "Alertas disparam antes do usuario perceber",
        "Zabbix cobre disponibilidade como segunda opiniao"
      ]
    }
  ]
}
