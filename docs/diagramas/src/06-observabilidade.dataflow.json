{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Pipeline de Telemetria",
    "subtitle": "Metricas via Prometheus (5 alvos), 4 dashboards no Grafana e Zabbix como segunda opiniao de disponibilidade",
    "viewBox": [980, 760]
  },
  "stages": [
    { "label": "Servicos" },
    { "label": "Coleta" },
    { "label": "Armazenamento" },
    { "label": "Visualizacao" }
  ],
  "nodes": [
    { "id": "gw", "type": "security", "label": "Gateway", "sublabel": "/metrics", "stage": 0, "row": 0 },
    { "id": "identity", "type": "backend", "label": "Identity.Api", "sublabel": "/metrics + /health", "stage": 0, "row": 1 },
    { "id": "campaigns", "type": "backend", "label": "Campaigns.Api", "sublabel": "/metrics + /health", "stage": 0, "row": 2 },
    { "id": "worker", "type": "backend", "label": "Worker", "sublabel": "consumo", "stage": 0, "row": 3 },
    { "id": "rabbit", "type": "messagebus", "label": "RabbitMQ", "sublabel": "plugin :15692", "stage": 0, "row": 4 },

    { "id": "prom", "type": "cloud", "label": "Prometheus", "sublabel": "scrape 5s", "stage": 1, "row": 1, "tag": "5 alvos" },
    { "id": "zabbix", "type": "cloud", "label": "Zabbix server", "sublabel": "checks HTTP :8080", "stage": 1, "row": 3 },

    { "id": "tsdb", "type": "database", "label": "TSDB", "sublabel": "series temporais", "stage": 2, "row": 1 },

    { "id": "grafana", "type": "frontend", "label": "Grafana", "sublabel": "4 dashboards", "stage": 3, "row": 1, "tag": "datasource Prometheus" },
    { "id": "zabbixweb", "type": "frontend", "label": "Zabbix Web", "sublabel": "disponibilidade", "stage": 3, "row": 3 }
  ],
  "flows": [
    { "from": "gw", "to": "prom", "label": "metrics" },
    { "from": "identity", "to": "prom", "label": "metrics" },
    { "from": "campaigns", "to": "prom", "label": "metrics", "variant": "emphasis" },
    { "from": "worker", "to": "prom", "label": "donations_*", "variant": "emphasis", "classification": "custom" },
    { "from": "rabbit", "to": "prom", "label": "ready / unacked", "labelDy": -22 },

    { "from": "campaigns", "to": "zabbix", "label": "check :8080", "variant": "dashed", "labelDy": 26 },

    { "from": "prom", "to": "tsdb", "label": "amostras", "variant": "emphasis" },
    { "from": "tsdb", "to": "grafana", "label": "PromQL", "variant": "emphasis", "classification": "read-only" },
    { "from": "zabbix", "to": "zabbixweb", "label": "status", "variant": "dashed" }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "Instrumentacao unica",
      "items": [
        "ServiceDefaults liga OTel (metricas), /health, /alive e resiliencia HTTP",
        "/metrics exposto por prometheus-net, inclusive no Gateway",
        "X-Correlation-Id do Gateway + traceparent propagado ate o Worker",
        "OTel pronto p/ exportar traces; sem Collector/Tempo no cluster, exporter off"
      ]
    },
    {
      "dot": "emerald",
      "title": "Metricas de negocio",
      "items": [
        "conexao_donations_processed_total / rejected_total",
        "conexao_outbox_pending_messages e dead_letter_messages",
        "conexao_donation_processing_duration_seconds",
        "Valor e contagem por campanha (label campanha)"
      ]
    },
    {
      "dot": "rose",
      "title": "Do sintoma a causa",
      "items": [
        "Prometheus faz scrape de 5 alvos: gateway, identity, campaigns, worker, rabbitmq",
        "Grafana: dashboards Aplicacao, Negocio, Mensageria e Saude (paineis, sem alerta provisionado)",
        "Zabbix faz check HTTP :8080 em identity-api, campaigns-api e donations-worker",
        "Zabbix cobre disponibilidade como segunda opiniao independente"
      ]
    }
  ]
}
