  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "Por que 202 e nao 200",
      "items": [
        "A API aceita a intencao e responde rapido",
        "O valor arrecadado so muda apos o Worker processar",
        "Desacopla recebimento de processamento",
        "A UI nunca confia apenas no 202"
      ]
    },
    {
      "dot": "emerald",
      "title": "Exactly-once efetivo",
      "items": [
        "Entrada: Idempotency-Key -> DonationId na mesma transacao",
        "Consumo: EventId gravado em processed_messages",
        "Publicacao: Outbox + publisher confirms",
        "Falha ao publicar mantem a mensagem pendente"
      ]
    },
    {
      "dot": "rose",
      "title": "Dois caminhos de confirmacao",
      "items": [
        "Tempo real: fanout -> NotificationConsumer -> SignalR",
        "Fallback: polling em GET /api/doacoes/{id}",
        "traceparent propagado ate o Worker (salto pela fila)",
        "Erro de consumo vai para retry 10s/60s e depois DLQ"
      ]
    }
  ]
}
