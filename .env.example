# Copie este arquivo para .env e preencha com valores reais.
# O .env NAO deve ser versionado (ja esta no .gitignore). Use apenas placeholders aqui.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=<defina-uma-senha-forte>
RABBITMQ_USER=<defina-um-usuario>
RABBITMQ_PASSWORD=<defina-uma-senha-forte>
JWT_SECRET=<gere-um-segredo-com-no-minimo-64-caracteres>
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<defina-uma-senha-forte>
ZABBIX_PASSWORD=<defina-uma-senha-forte>
SEED_MANAGER_PASSWORD=<defina-uma-senha-forte-para-o-gestor-seed>
# Opcional: habilita as features de IA (Assistente Solidario + criacao assistida de campanhas).
# Vazio/ausente = o app sobe normalmente com as features de IA ocultas.
OPENAI_API_KEY=
